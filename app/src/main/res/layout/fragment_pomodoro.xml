<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:scrollbars="vertical"
    android:fadeScrollbars="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:paddingBottom="48dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍅 Pomodoro"
            android:textColor="@color/color_text_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_pomodoro_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tập trung"
            android:textColor="@color/color_primary"
            android:textSize="15sp"
            android:letterSpacing="0.05"
            android:layout_marginBottom="40dp" />

        <!-- Timer Circle -->
        <FrameLayout
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginBottom="40dp">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/pomodoro_progress"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                app:trackThickness="10dp"
                app:indicatorColor="@color/color_primary"
                app:trackColor="@color/color_surface_variant"
                app:indicatorSize="240dp"
                android:progress="100" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tv_timer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25:00"
                    android:textColor="@color/color_text_primary"
                    android:textSize="52sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tv_session_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phiên 1/4"
                    android:textColor="@color/color_text_hint"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- Mode Chips -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_pomodoro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:singleSelection="true"
            app:chipSpacingHorizontal="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_work"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tập trung (25p)"
                style="@style/Widget.Modern.Chip"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_short_break"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nghỉ ngắn (5p)"
                style="@style/Widget.Modern.Chip" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_long_break"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nghỉ dài (15p)"
                style="@style/Widget.Modern.Chip" />

        </com.google.android.material.chip.ChipGroup>

        <!-- Focus Sounds -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎵 Âm thanh tập trung (Bật khi chạy)"
            android:textColor="@color/color_text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="12dp"
            android:fontFamily="sans-serif-medium"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingEnd="12dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sound_none"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Yên tĩnh"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:checked="true"
                    app:chipIcon="@drawable/ic_check"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sound_rain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tiếng mưa"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipIcon="@drawable/ic_rain"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sound_cafe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quán Cafe"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipIcon="@drawable/ic_cafe"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sound_lofi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhạc Lo-fi"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipIcon="@drawable/ic_music"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_sound_nature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thiên nhiên"
                    style="@style/Widget.Material3.Chip.Filter"
                    app:chipIcon="@drawable/ic_nature" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pomodoro_reset"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_search"
                app:iconTint="@color/color_text_secondary"
                app:backgroundTint="@color/color_surface_variant"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="Đặt lại" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pomodoro_start"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="Bắt đầu"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                app:backgroundTint="@color/color_primary"
                app:cornerRadius="28dp"
                app:elevation="4dp"
                app:icon="@drawable/ic_check"
                app:iconTint="@color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pomodoro_skip"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_skip_next"
                app:iconTint="@color/color_text_secondary"
                app:backgroundTint="@color/color_surface_variant"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                android:layout_marginStart="16dp"
                android:contentDescription="Bỏ qua" />

        </LinearLayout>

        <!-- Tip text -->
        <TextView
            android:id="@+id/tv_pomodoro_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💡 Tập trung 25 phút, nghỉ 5 phút. Sau 4 phiên, nghỉ 15 phút."
            android:textColor="@color/color_text_hint"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="32dp" />

    </LinearLayout>

</ScrollView>
